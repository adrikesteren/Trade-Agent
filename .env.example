# Put this file at the repo root (recommended). Next.js is configured with `envDir`
# pointing at the monorepo root, so `apps/web` loads these values automatically.
# You can still use apps/web/.env.local for overrides. Never commit real keys.
#
# Repo `.env*` is loaded with `override: true` in `apps/web/next.config.ts`, so values here beat stray User/System/shell env vars. Prefer keeping secrets only in these files.
#
# Keep your private `.env` aligned with this template: every `process.env.*` used by
# `apps/web` should appear here (empty = optional). Copy missing keys into `.env` as needed.

# No space after `=` — a leading space in the URL breaks Auth/API (workers + dashboard).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# IANA tz for market chart axis/crosshair/hover (bars remain UTC; labels only). Example: UTC, Europe/London
NEXT_PUBLIC_CHART_DISPLAY_TIMEZONE=

# Server only — workers / API routes (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bitvavo — live private REST (orders + reconcile) uses per-executor `exchange_api_key` / `exchange_api_secret`
# in `trading.executors` (Dashboard → Executors → Edit). Leave unset unless you still rely on legacy tooling.
BITVAVO_API_KEY=
BITVAVO_API_SECRET=

# Not read by current `apps/web` sources (legacy / local experiments). Safe to leave unset.
BITVAVO_MARKET_SYNC_BACKFILL_MAX_MARKETS=

# --- Relay (optional) — `exchange-close-pipeline` ordered fan-out to `symbol-close-pipeline` ---
# Self-hosted Relay ingress (see Relay repo AGENTS.md). Example local: http://localhost:1337
RELAY_APP_URL=
# Bearer for POST /api/v1/messages and /api/v1/message-group on Relay (server-to-server only).
RELAY_APP_SECRET=
# Public base URL of this Next app (no trailing slash). Worker URLs enqueued on Relay point here, e.g. http://localhost:3000
APP_URL=
# Optional: maxRetries passed to Relay for each enqueued job (default 2, max 100 per Relay).
RELAY_EXCHANGE_CLOSE_MAX_RETRIES=

# Optional: Bearer for workers if not stored in Postgres. Prefer `public.system_settings` key `cron_secret`
# (JSON string or {"secret":"…"}). Same value is forwarded in Relay job `headers` when enqueueing exchange-close jobs.
CRON_SECRET=

# Optional: operator JSON webhook on selected worker failures (see apps/web/src/lib/ops/send-ops-alert.ts)
OPS_ALERT_WEBHOOK_URL=

# Optional: Slack Incoming Webhook for #trade-fills — POST { "text": "…" } when an executor fill is persisted
# (executor-catalog-close or bitvavo-reconcile). Create in Slack: App → Incoming Webhooks → channel #trade-fills.
SLACK_TRADE_FILLS_WEBHOOK_URL=

# --- Signal agents (`POST /api/workers/signals-catalog-close`, incremental EUR `15m` candle sweep) ---
# Pipeline `user_id`: **only** Automated Process — `public.automation_actor` or `user_profiles.username = automated_process`, validated against auth.
# `SIGNAL_USER_IDS` below is legacy/unused by the catalog pipeline (remove from real `.env` when cleaning up).
SIGNAL_USER_IDS=
# Optional: set to 1 to skip enqueueing signal runs after a successful incremental candle sweep
SIGNALS_AFTER_CANDLE_DISABLE=
# Optional: markets per worker POST (default 40)
SIGNALS_CATALOG_CLOSE_MARKET_BATCH_SIZE=
# Optional: cap total markets processed per logical close (unset = all EUR Bitvavo markets)
SIGNALS_CATALOG_CLOSE_MAX_TOTAL_MARKETS=
# Optional: max in-process market batches per signals/mediator/executor drain (default 400)
SIGNALS_CATALOG_CLOSE_INLINE_MAX_ITERS=

# Optional: Assets page "next tick" display (ms). 0 or unset = no ETA for that row. Market POST /api/markets/bitvavo/sync requires ?source=manual (automated calls return 400).
NEXT_PUBLIC_BITVAVO_MARKETS_SYNC_INTERVAL_MS=
# Optional: same for candles row (default in code 900000 if unset).
NEXT_PUBLIC_BITVAVO_CANDLES_SYNC_INTERVAL_MS=
# Optional: Sync runs page “next grid” hint for CoinGecko job (default 300000). Set 0 to hide the ETA column logic for that row.
NEXT_PUBLIC_COINGECKO_METRICS_SYNC_INTERVAL_MS=
# Same for the CoinGecko coin-id backfill worker (`assets.coingecko_coin_id`; default 300000).
NEXT_PUBLIC_COINGECKO_COIN_ID_SYNC_INTERVAL_MS=

# Worker: max Bitvavo candle chunks before the inline remainder loop continues in the same request (default 8)
BITVAVO_CANDLES_SYNC_MAX_CHUNKS_PER_RUN=

# Local dev only (NODE_ENV=development): run full EUR candle sweep on a timer inside the Next server. Default interval 15 minutes.
ENABLE_LOCAL_CANDLE_AUTO_SYNC=
LOCAL_CANDLE_SYNC_INTERVAL_MS=

# Worker: optional — when `1`, skip the first short chunk phase and run only the inline remainder style (legacy tuning).
BITVAVO_CANDLES_SYNC_INLINE_CHAIN=
# Max extra chunks / max duration (ms) for that inline continuation
BITVAVO_CANDLES_SYNC_INLINE_MAX_CHUNKS=
BITVAVO_CANDLES_SYNC_INLINE_MAX_MS=

# Optional: max wall clock (ms) a row may stay `running` in `automation.sync_runs` before auto-failed (default 600000 = 10 min). Clamped 60000–86400000.
SYNC_RUN_RUNNING_TIMEOUT_MS=

# CoinGecko (public API; optional Pro/demo key as x-cg-demo-api-key for higher limits)
COINGECKO_API_KEY=
# Max CoinGecko /search calls per HTTP job (default 200); worker runs inline until the slice completes or limits hit.
COINGECKO_MAX_SEARCH_CALLS_PER_JOB=
# Max /search calls per run for filling `assets.coingecko_coin_id` only (default 60).
COINGECKO_COIN_ID_SEARCH_MAX_PER_RUN=
# Deprecated alias for COINGECKO_MAX_SEARCH_CALLS_PER_JOB
COINGECKO_MAX_SEARCH_ATTEMPTS_PER_RUN=
# Delay between /search calls in ms (default 1200). Worst case per job slice ≈ max_search × this (e.g. 200×1.2s ≈ 4 min) before markets + DB.
COINGECKO_SEARCH_DELAY_MS=
# Parallel catalog `assets` updates after /coins/markets (default 25). Higher = faster phase 2, watch Supabase/connection limits.
COINGECKO_MARKETS_DB_CONCURRENCY=
# Optional: call GET /api/workers/coingecko-metrics-sync or GET /api/workers/assets/find-coingecko-id?all=true on a timer with Authorization: Bearer CRON_SECRET (same work as POST). Legacy GET /api/workers/coingecko-coin-id-sync still delegates to `?all=true`.

# Local dev only: poll CoinGecko for catalog crypto assets on a timer (default 5 minutes). Requires NODE_ENV=development.
ENABLE_LOCAL_COINGECKO_METRICS_SYNC=
LOCAL_COINGECKO_METRICS_INTERVAL_MS=

# Local dev only: backfill `assets.coingecko_coin_id` on a timer (default 5 minutes). Requires NODE_ENV=development.
ENABLE_LOCAL_COINGECKO_COIN_ID_SYNC=
LOCAL_COINGECKO_COIN_ID_INTERVAL_MS=
